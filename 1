import { GoogleGenerativeAI } from '@google/generative-ai';
import { SummarySchema } from './types';

const TIMEOUT_MS = 30000;

chrome.runtime.onMessage.addListener((message, _sender, sendResponse) => {
  if (message.action === 'SUMMARIZE_CONTENT') {
    handleSummarization(message.payload, sendResponse);
    return true;
  }
  return false;
});

async function handleSummarization(payload: any, sendResponse: (res: any) => void) {
  const timeout = setTimeout(() => {
    sendResponse({ success: false, error: 'Request timed out' });
  }, TIMEOUT_MS);

  try {
    const { apiKey } = await chrome.storage.local.get('apiKey') as { apiKey?: string };
    if (!apiKey) throw new Error('API Key missing in settings');

    const genAI = new GoogleGenerativeAI(apiKey);
    const model = genAI.getGenerativeModel({ model: 'gemini-2.5-flash-lite' });

    const prompt = `Summarize in JSON: {"summary":[], "keyInsights":[], "readingTime":""}. Article: ${payload.content}`;

    const result = await model.generateContent(prompt);
    const responseText = result.response.text();

    const jsonMatch = responseText.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error('Invalid AI response format');

    const summaryData = SummarySchema.parse(JSON.parse(jsonMatch[0]));
    clearTimeout(timeout);
    sendResponse({ success: true, data: summaryData });
  } catch (error: any) {
    clearTimeout(timeout);
    sendResponse({ success: false, error: error.message || 'Summarization failed' });
  }
}
